{
	"name": "janburzinski-web",
	"private": true,
	"version": "1.0.0",
	"type": "module",
	"packageManager": "pnpm@11.9.0",
	"portless": {
		"name": "janburzinski-web",
		"script": "dev:app"
	},
	"scripts": {
		"preinstall": "node -e \"const ua=process.env.npm_config_user_agent||''; if(!ua.startsWith('pnpm/')){console.error('Use pnpm to install dependencies.'); process.exit(1)}\"",
		"dev": "portless run",
		"dev:app": "vite dev",
		"build": "vite build",
		"start": "node build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test": "vitest run",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"deploy": "wrangler deploy",
		"dev:remote": "wrangler dev --remote",
		"db:push": "drizzle-kit push",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio"
	},
	"devDependencies": {
		"@eslint/compat": "^1.4.1",
		"@eslint/js": "^9.39.2",
		"@sveltejs/adapter-cloudflare": "^7.2.8",
		"@sveltejs/adapter-node": "^5.3.3",
		"@sveltejs/adapter-vercel": "^6.3.3",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@types/pg": "^8.20.0",
		"drizzle-kit": "^0.31.10",
		"eslint": "^9.39.2",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.14.0",
		"globals": "^16.5.0",
		"portless": "^0.15.1",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.4.1",
		"svelte": "^5.50.0",
		"svelte-check": "^4.3.6",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.54.0",
		"vite": "^7.3.1",
		"vitest": "^4.1.10",
		"wrangler": "^4.76.0"
	},
	"dependencies": {
		"@fontsource/geist": "^5.2.9",
		"@fontsource/geist-mono": "^5.2.8",
		"@fontsource/inter": "^5.2.8",
		"@vercel/functions": "^3.7.5",
		"drizzle-orm": "^0.45.2",
		"lucide-svelte": "^0.563.0",
		"pg": "^8.22.0"
	}
}
